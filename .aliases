alias _='sudo'
alias astudio='sh ~/dev/android-studio/bin/studio.sh'
alias vi=vim
_AI_SERVICES="ollama open-webui honcho honcho-deriver honcho-db honcho-redis firecrawl firecrawl-playwright firecrawl-postgres firecrawl-rabbitmq firecrawl-redis harbor-cat"
alias ai-off='ssh ssh.skyler.is "cd ~/services && podman-compose stop $_AI_SERVICES"'
alias ai-on='ssh ssh.skyler.is "cd ~/services && podman-compose start $_AI_SERVICES"'

_AI_SUPPORT="honcho honcho-deriver honcho-db honcho-redis firecrawl firecrawl-playwright firecrawl-postgres firecrawl-rabbitmq firecrawl-redis"
alias ai-support-on='ssh ssh.skyler.is "cd ~/services && podman-compose start $_AI_SUPPORT"'
alias ai-support-off='ssh ssh.skyler.is "cd ~/services && podman-compose stop $_AI_SUPPORT"'

_honcho_set_endpoint() {
  python3 - "$HOME/.honcho/config.json" "$1" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
base_url = sys.argv[2]
data = json.loads(path.read_text())
fallback = "http://orphic-lens:8100" if "localhost" in base_url or "127.0.0.1" in base_url else "http://localhost:8100"
candidates = [base_url]
if fallback not in candidates:
    candidates.append(fallback)
data.setdefault("endpoint", {})["baseUrl"] = base_url
data["endpoint"]["candidates"] = candidates
path.write_text(json.dumps(data, indent=2) + "\n")
PY
}
honcho-up() {
  ssh -f -N -o ServerAliveInterval=60 -L 8100:localhost:8100 ssh.skyler.is &&
    _honcho_set_endpoint "http://localhost:8100" &&
    echo "Honcho tunnel up (localhost:8100)"
}
honcho-down() {
  pkill -f "ssh.*-L 8100:localhost:8100" 2>/dev/null || true
  _honcho_set_endpoint "http://orphic-lens:8100"
  echo "Honcho tunnel down; Honcho endpoint set to LAN (orphic-lens)"
}
honcho-lan() {
  _honcho_set_endpoint "http://orphic-lens:8100"
  echo "Honcho endpoint set to LAN (orphic-lens)"
}
honcho-tunnel() {
  _honcho_set_endpoint "http://localhost:8100"
  echo "Honcho endpoint set to tunnel (localhost:8100)"
}
honcho-status() {
  if pgrep -f "ssh.*-L 8100:localhost:8100" >/dev/null; then
    echo "Honcho tunnel: UP (pid $(pgrep -f "ssh.*-L 8100:localhost:8100" | paste -sd, -))"
  else
    echo "Honcho tunnel: DOWN"
  fi
  python3 - "$HOME/.honcho/config.json" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
endpoint = json.loads(path.read_text()).get("endpoint", {})
print(f"Honcho endpoint: {endpoint.get('baseUrl', 'unset')}")
print(f"Honcho candidates: {', '.join(endpoint.get('candidates', []))}")
PY
}

_hermes_set_endpoint() {
  python3 - "$HOME/.hermes/config.yaml" "$HOME/.hermes/honcho.json" "$1" "$2" <<'PY'
import json
import sys
from pathlib import Path

import yaml

config_path = Path(sys.argv[1])
honcho_path = Path(sys.argv[2])
llm_base_url = sys.argv[3]
honcho_base_url = sys.argv[4]

if config_path.exists():
    data = yaml.safe_load(config_path.read_text()) or {}
    for block in (
        data.get("model"),
        data.get("delegation"),
    ):
        if isinstance(block, dict):
            block["base_url"] = llm_base_url
    compression = data.get("compression")
    if isinstance(compression, dict):
        compression["summary_base_url"] = llm_base_url
    auxiliary = data.get("auxiliary")
    if isinstance(auxiliary, dict):
        for block in auxiliary.values():
            if isinstance(block, dict) and "base_url" in block:
                block["base_url"] = llm_base_url
    providers = data.get("custom_providers")
    if isinstance(providers, list):
        for provider in providers:
            if isinstance(provider, dict) and provider.get("name") == "orphic-lens":
                provider["base_url"] = llm_base_url
    config_path.write_text(yaml.safe_dump(data, sort_keys=False, allow_unicode=True))

if honcho_path.exists():
    data = json.loads(honcho_path.read_text())
    data["baseUrl"] = honcho_base_url
    honcho_path.write_text(json.dumps(data, indent=2) + "\n")
PY
}
hermes-tunnel() {
  _hermes_set_endpoint "http://127.0.0.1:11434/v1" "http://127.0.0.1:8100"
  echo "Hermes endpoint set to tunnel (127.0.0.1)"
}
hermes-lan() {
  _hermes_set_endpoint "http://orphic-lens:11434/v1" "http://orphic-lens:8100"
  echo "Hermes endpoint set to LAN (orphic-lens)"
}
hermes-up() {
  honcho-up
  if ! pgrep -f "ssh.*-L 11434:localhost:11434" >/dev/null; then
    ssh -f -N -o ServerAliveInterval=60 -o ExitOnForwardFailure=yes \
      -L 11434:localhost:11434 ssh.skyler.is
  fi
  hermes-tunnel
  echo "Hermes tunnel up (localhost:11434)"
}
hermes-down() {
  pkill -f "ssh.*-L 11434:localhost:11434" 2>/dev/null || true
  hermes-lan
  echo "Hermes tunnel down"
}
hermes-status() {
  if pgrep -f "ssh.*-L 11434:localhost:11434" >/dev/null; then
    echo "Hermes LLM tunnel: UP (pid $(pgrep -f "ssh.*-L 11434:localhost:11434" | paste -sd, -))"
  else
    echo "Hermes LLM tunnel: DOWN"
  fi
  python3 - "$HOME/.hermes/config.yaml" "$HOME/.hermes/honcho.json" <<'PY'
import json
import sys
from pathlib import Path

import yaml

config_path = Path(sys.argv[1])
honcho_path = Path(sys.argv[2])
if config_path.exists():
    data = yaml.safe_load(config_path.read_text()) or {}
    print(f"Hermes LLM endpoint: {data.get('model', {}).get('base_url', 'unset')}")
if honcho_path.exists():
    data = json.loads(honcho_path.read_text())
    print(f"Hermes Honcho endpoint: {data.get('baseUrl', 'unset')}")
PY
}
