alias _='sudo'
alias astudio='sh ~/dev/android-studio/bin/studio.sh'
alias python="/home/linuxbrew/.linuxbrew/bin/python3"
alias vi=vim
_AI_SERVICES="ollama open-webui honcho honcho-deriver honcho-db honcho-redis firecrawl firecrawl-playwright firecrawl-postgres firecrawl-rabbitmq firecrawl-redis harbor-cat"
alias ai-off='ssh ssh.skyler.is "cd ~/services && podman-compose stop $_AI_SERVICES"'
alias ai-on='ssh ssh.skyler.is "cd ~/services && podman-compose start $_AI_SERVICES"'

_AI_SUPPORT="honcho honcho-deriver honcho-db honcho-redis firecrawl firecrawl-playwright firecrawl-postgres firecrawl-rabbitmq firecrawl-redis"
alias ai-support-on='ssh ssh.skyler.is "cd ~/services && podman-compose start $_AI_SUPPORT"'
alias ai-support-off='ssh ssh.skyler.is "cd ~/services && podman-compose stop $_AI_SUPPORT"'

_HERMES_CONFIGS="$HOME/.hermes/config.yaml $HOME/.hermes/honcho.json $HOME/.hermes/.env"
alias hermes-tunnel='sed -i "s|orphic-lens|127.0.0.1|g" $_HERMES_CONFIGS && echo "Hermes → tunnel (127.0.0.1)"'
alias hermes-lan='sed -i "s|127\.0\.0\.1|orphic-lens|g" $_HERMES_CONFIGS && echo "Hermes → LAN (orphic-lens)"'
