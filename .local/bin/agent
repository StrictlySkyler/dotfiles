#!/usr/bin/env bash
# Wrapper for cursor-agent.
#
# Note: xterm "alternate screen" (CSI ? 1049 h) intentionally has *no scrollback*
# in ConEmu (and most terminals), which makes the agent output feel "unscrollable".
# Default to the normal screen buffer so you can scroll normally.
#
# Set CURSOR_AGENT_ALT_SCREEN=1 to opt into alternate-screen behavior.
set -uo pipefail

real="$(ls -t "$HOME"/.local/share/cursor-agent/versions/*/cursor-agent 2>/dev/null | head -1 || true)"
if [[ -z "$real" || ! -x "$real" ]]; then
  echo "cursor-agent not found" >&2
  exit 1
fi

# Pass through subcommands that don't use the TUI
case "${1:-}" in
  --print|-p|record|update) exec "$real" "$@" ;;
esac

# Only do terminal control when we're actually in an interactive terminal
if [[ ! -t 0 || ! -t 1 ]]; then
  exec "$real" "$@"
fi

[[ -z "${TERM:-}" || "${TERM:-}" == dumb ]] && export TERM=xterm-256color

_alt="${CURSOR_AGENT_ALT_SCREEN:-0}"
case "$_alt" in
  1|true|TRUE|True|yes|YES|Yes|on|ON|On) _alt=1 ;;
  *) _alt=0 ;;
esac

_stty_state="$(stty -g 2>/dev/null || true)"
_cleanup() {
  if [[ -n "${_stty_state:-}" ]]; then
    stty "$_stty_state" 2>/dev/null || true
  fi
  if [[ "${_alt:-0}" == 1 ]]; then
    printf "\e[?1049l"
  fi
}
trap _cleanup EXIT INT TERM HUP

if [[ "$_alt" == 1 ]]; then
  printf '\e[?1049h\e[2J\e[H'
fi

"$real" "$@"
