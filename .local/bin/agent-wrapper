#!/usr/bin/env bash
set -euo pipefail

REAL_AGENT="$(ls -t /home/skyler/.local/share/cursor-agent/versions/*/cursor-agent 2>/dev/null | head -1)"
if [ -z "$REAL_AGENT" ]; then
  echo "Error: cursor-agent not found" >&2
  exit 1
fi

if [[ "${1:-}" == "--print" ]] || [[ "${1:-}" == "-p" ]] || [[ "${1:-}" == "record" ]] || [[ "${1:-}" == "update" ]]; then
  exec "$REAL_AGENT" "$@"
fi

cleanup() {
  printf '\e[?1049l'
  stty sane 2>/dev/null || true
}
trap cleanup EXIT INT TERM

printf '\e[?1049h'
printf '\e[2J\e[H'
"$REAL_AGENT" "$@"
